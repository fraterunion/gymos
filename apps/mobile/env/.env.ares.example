# Example: Ares Training Club branded build.
# Copy to: env/.env.ares
# Build / prebuild: WHITELABEL_PROFILE=ares pnpm exec expo prebuild (or EAS with same env).

EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_STUDIO_SLUG=ares-fitness

APP_DISPLAY_NAME=Ares Training Club
# iOS CFBundleDisplayName / Android android:label (home screen / launcher).
# App Store and Play Store names are set in their respective store consoles — not here.
APP_LAUNCHER_NAME=ARES
APP_SCHEME=aresfitness
EXPO_SLUG=ares-fitness-member

IOS_BUNDLE_IDENTIFIER=com.aresfitness.member
ANDROID_PACKAGE=com.aresfitness.member

# Premium minimalist ARES mark (paths relative to apps/mobile/).
APP_ICON_PATH=./assets/branding/ares/icon.png
APP_SPLASH_PATH=./assets/branding/ares/splash-logo.png
APP_SPLASH_BG_COLOR=#000000
APP_ADAPTIVE_ICON_PATH=./assets/branding/ares/adaptive-icon.png
APP_ADAPTIVE_ICON_BG_COLOR=#000000
APP_VERSION=1.0.0
IOS_BUILD_NUMBER=3

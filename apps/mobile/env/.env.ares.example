# Example: ARES Fitness branded build.
# Copy to: env/.env.ares
# Build / prebuild: WHITELABEL_PROFILE=ares pnpm exec expo prebuild (or EAS with same env).

EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_STUDIO_SLUG=ares-fitness

APP_DISPLAY_NAME=ARES Fitness
APP_SCHEME=aresfitness
EXPO_SLUG=ares-fitness-member

IOS_BUNDLE_IDENTIFIER=com.aresfitness.member
ANDROID_PACKAGE=com.aresfitness.member

# Point to checked-in or CI-supplied assets (paths relative to apps/mobile/).
APP_ICON_PATH=./assets/images/icon.png
APP_SPLASH_PATH=./assets/images/splash-icon.png
APP_ADAPTIVE_ICON_PATH=./assets/images/adaptive-icon.png

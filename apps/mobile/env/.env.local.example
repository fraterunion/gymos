# Local / template profile (WHITELABEL_PROFILE=local or unset).
# Copy to: env/.env.local
#
# Metro still reads EXPO_PUBLIC_* from this file when present (bundle time).
# Optional: duplicate EXPO_PUBLIC_* in apps/mobile/.env instead.

EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_STUDIO_SLUG=your-studio-slug

# Native shell — optional here; defaults in app.config.ts apply for profile "local".
# APP_DISPLAY_NAME=My Studio Dev
# APP_SCHEME=gymosdev
# IOS_BUNDLE_IDENTIFIER=com.example.dev.member
# ANDROID_PACKAGE=com.example.dev.member
# EXPO_SLUG=my-studio-member
# APP_ICON_PATH=./assets/images/icon.png
# APP_SPLASH_PATH=./assets/images/splash-icon.png
# APP_ADAPTIVE_ICON_PATH=./assets/images/adaptive-icon.png

# Example: Pilates Toluca branded build.
# Copy to: env/.env.pilates-toluca
# Build: WHITELABEL_PROFILE=pilates-toluca pnpm exec expo prebuild (or EAS).

EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_STUDIO_SLUG=pilates-toluca

APP_DISPLAY_NAME=Pilates Toluca
APP_SCHEME=pilatestoluca
EXPO_SLUG=pilates-toluca-member

IOS_BUNDLE_IDENTIFIER=com.pilatestoluca.member
ANDROID_PACKAGE=com.pilatestoluca.member

APP_ICON_PATH=./assets/images/icon.png
APP_SPLASH_PATH=./assets/images/splash-icon.png
APP_ADAPTIVE_ICON_PATH=./assets/images/adaptive-icon.png

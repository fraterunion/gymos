{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "0.0.0",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export -p web --output-dir dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .expo .turbo",
    "config:print": "node scripts/print-app-config.cjs",
    "eas:config:ares": "cross-env WHITELABEL_PROFILE=ares node scripts/print-app-config.cjs",
    "eas:config:pilates": "cross-env WHITELABEL_PROFILE=pilates-toluca node scripts/print-app-config.cjs",
    "eas:build:ios:ares": "eas build --platform ios --profile preview-ares",
    "eas:build:android:ares": "eas build --platform android --profile preview-ares",
    "eas:build:ios:pilates": "eas build --platform ios --profile preview-pilates-toluca",
    "eas:build:android:pilates": "eas build --platform android --profile preview-pilates-toluca",
    "eas:build:ios:preview": "eas build --platform ios --profile preview",
    "eas:build:android:preview": "eas build --platform android --profile preview",
    "eas:build:ios:production": "eas build --platform ios --profile production",
    "eas:build:android:production": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "7.4.0",
    "@react-navigation/native": "7.1.8",
    "@stripe/stripe-react-native": "^0.50.3",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.3",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@gymos/config": "workspace:*",
    "@types/react": "~19.1.17",
    "cross-env": "^7.0.3",
    "eas-cli": "^16.0.0",
    "eslint": "^9.27.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.32.1"
  },
  "private": true
}

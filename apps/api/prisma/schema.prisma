generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  MEMBER
  INSTRUCTOR
  STAFF
  ADMIN
  OWNER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  WEEKLY
}

enum ClassStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum CancelSource {
  MEMBER
  STUDIO
  SYSTEM
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
  EXPIRED
}

enum CheckInMethod {
  QR
  MANUAL
  KIOSK
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum EnrollmentFeeStatus {
  PAID
  WAIVED
}

enum WaivedReason {
  FIRST_N_PROMO
  FIRST_N_PROMO_OVERFLOW
  ADMIN_WAIVER
  STAFF
  LEGACY_MEMBER
  OTHER
}

enum CampaignType {
  FIRST_N_MEMBERS
}

enum CampaignAppliesTo {
  ENROLLMENT_FEE
}

enum BuildJobPlatform {
  IOS
  ANDROID
}

enum BuildJobProfile {
  PREVIEW
  PRODUCTION
}

enum BuildJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum BuildJobErrorCategory {
  CONFIG_ERROR
  AUTH_ERROR
  EAS_OUTAGE
  BUILD_FAILED
  TIMEOUT
  UNKNOWN
}

enum StaffType {
  COACH
  FRONT_DESK
  MANAGER
  OPERATIONS
  OTHER
}

enum IntensityLevel {
  LOW
  MEDIUM
  HIGH
  EXTREME
}

enum ClassCategory {
  STRENGTH
  HIIT
  YOGA
  PILATES
  BOXING
  RUNNING
  RECOVERY
  MOBILITY
  CYCLING
  HYROX
  OTHER
}

enum DayPassStatus {
  PENDING
  ACTIVE
  EXPIRED
  REFUNDED
}

enum ScheduleGenerationTrigger {
  MANUAL
  AUTOMATIC
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Studio {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  timezone  String    @default("UTC")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  appName              String? @map("app_name")
  brandPrimaryColor    String? @map("brand_primary_color")
  brandSecondaryColor  String? @map("brand_secondary_color")
  brandLogoUrl         String? @map("brand_logo_url")
  brandIconUrl         String? @map("brand_icon_url")
  brandSplashUrl       String? @map("brand_splash_url")
  supportEmail         String? @map("support_email")
  supportPhone         String? @map("support_phone")
  privacyUrl           String? @map("privacy_url")
  termsUrl             String? @map("terms_url")
  iosBundleId          String? @map("ios_bundle_id")
  androidPackageName   String? @map("android_package_name")
  appStoreUrl          String? @map("app_store_url")
  playStoreUrl         String? @map("play_store_url")

  /// Phase 12 — desk settings (additive). Public API prefers these over legacy brand* when set.
  logoUrl                       String? @map("logo_url")
  coverImageUrl                 String? @map("cover_image_url")
  primaryColor                  String? @map("primary_color")
  accentColor                   String? @map("accent_color")
  websiteUrl                    String? @map("website_url")
  instagramHandle               String? @map("instagram_handle")
  address                       String? @map("address")
  allowWaitlist                 Boolean @default(true) @map("allow_waitlist")
  autoConfirmWaitlist           Boolean @default(false) @map("auto_confirm_waitlist")
  cancellationWindowHours       Int     @default(12) @map("cancellation_window_hours")
  lateCancelPenaltyEnabled      Boolean @default(false) @map("late_cancel_penalty_enabled")
  checkInWindowMinutes          Int     @default(15) @map("check_in_window_minutes")
  appDisplayName                String? @map("app_display_name")
  appScheme                     String? @map("app_scheme")
  expoSlug                      String? @map("expo_slug")

  memberships    StudioMembership[]
  plans          MembershipPlan[]
  subscriptions  Subscription[]
  classTemplates ClassTemplate[]
  classes        ScheduledClass[]
  bookings       Booking[]
  waitlist       WaitlistEntry[]
  attendances    Attendance[]
  qrTokens       QRToken[]
  payments       Payment[]
  buildJobs                  BuildJob[]
  staffProfiles              StudioStaffProfile[]
  memberCrmProfiles          StudioMemberProfile[]
  dayPasses                  DayPass[]
  scheduleTemplates          ScheduleTemplate[]
  scheduleGenerationRuns     ScheduleGenerationRun[]
  scheduleAutomationSettings ScheduleAutomationSettings?
  enrollmentSettings         StudioEnrollmentSettings?
  memberEnrollments          MemberEnrollment[]

  @@map("studios")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  phone            String?   @map("phone")
  passwordHash     String?   @map("password_hash")
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  studioMemberships StudioMembership[]
  subscriptions     Subscription[]     @relation("SubscriptionMember")
  bookings            Booking[]
  waitlistEntries     WaitlistEntry[]
  attendances         Attendance[]
  attendancesRecorded Attendance[]       @relation("AttendanceRecordedBy")
  qrTokens            QRToken[]
  payments            Payment[]
  refreshTokens       RefreshToken[]
  instructedClasses           ScheduledClass[]        @relation("ScheduledClassInstructor")
  defaultClassTemplates       ClassTemplate[]         @relation("ClassTemplateDefaultInstructor")
  buildJobsRequested          BuildJob[]
  staffProfiles               StudioStaffProfile[]
  memberCrmProfiles           StudioMemberProfile[]
  dayPasses                   DayPass[]
  instructedScheduleTemplates ScheduleTemplate[]      @relation("ScheduleTemplateInstructor")
  scheduleGenerationRuns      ScheduleGenerationRun[] @relation("ScheduleGenerationRunUser")
  enrollments                 MemberEnrollment[]

  @@map("users")
}

model StudioMembership {
  id        String    @id @default(cuid())
  studioId String    @map("studio_id")
  userId   String    @map("user_id")
  role      Role
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, studioId])
  @@index([studioId])
  @@index([studioId, userId])
  @@map("studio_memberships")
}

model MembershipPlan {
  id               String          @id @default(cuid())
  studioId         String          @map("studio_id")
  name             String
  description      String?
  priceCents       Int             @map("price_cents")
  currency         String          @default("usd")
  billingInterval  BillingInterval @map("billing_interval")
  /// When null, plan grants unlimited class credits for billing purposes.
  classCredits     Int?            @map("class_credits")
  active           Boolean         @default(true)
  /// Direct Stripe Billing (Phase 4A): synced product for this plan.
  stripeProductId  String?        @map("stripe_product_id")
  /// Direct Stripe Billing (Phase 4A): recurring price for this plan.
  stripePriceId    String?        @map("stripe_price_id")
  /// Phase 26 — class entitlements. Empty = all-access. Non-empty = member may
  /// only book classes whose classTemplate.category is in this list.
  /// Day Pass access is never restricted by this field.
  allowedCategories ClassCategory[] @default([]) @map("allowed_categories")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  studio        Studio         @relation(fields: [studioId], references: [id], onDelete: Restrict)
  subscriptions Subscription[]
  payments      Payment[]

  @@index([studioId])
  @@index([studioId, active])
  @@map("membership_plans")
}

model Subscription {
  id                   String               @id @default(cuid())
  studioId             String               @map("studio_id")
  userId               String               @map("user_id")
  membershipPlanId     String               @map("membership_plan_id")
  status               SubscriptionStatus
  stripeSubscriptionId String?              @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime?            @map("current_period_start")
  currentPeriodEnd     DateTime?            @map("current_period_end")
  cancelAtPeriodEnd    Boolean              @default(false) @map("cancel_at_period_end")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  studio         Studio         @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user           User           @relation("SubscriptionMember", fields: [userId], references: [id], onDelete: Restrict)
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: Restrict)
  payments       Payment[]

  @@index([studioId])
  @@index([studioId, userId])
  @@index([userId])
  @@index([membershipPlanId])
  @@index([status])
  @@map("subscriptions")
}

model ClassTemplate {
  id                   String          @id @default(cuid())
  studioId             String          @map("studio_id")
  name                 String
  durationMinutes      Int             @map("duration_minutes")
  description          String?
  defaultCapacity      Int             @default(10) @map("default_capacity")
  color                String?
  defaultInstructorId  String?         @map("default_instructor_id")

  /// Phase 21 — rich metadata
  intensityLevel         IntensityLevel? @map("intensity_level")
  category               ClassCategory?
  equipment              String[]
  heroImageUrl           String?         @map("hero_image_url")
  thumbnailImageUrl      String?         @map("thumbnail_image_url")
  tags                   String[]
  isFeatured             Boolean         @default(false) @map("is_featured")
  difficultyLabel        String?         @map("difficulty_label")
  caloriesEstimateMin    Int?            @map("calories_estimate_min")
  caloriesEstimateMax    Int?            @map("calories_estimate_max")
  cancellationWindowHours Int?           @map("cancellation_window_hours")
  waitlistCapacity       Int?            @map("waitlist_capacity")

  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  deletedAt            DateTime?       @map("deleted_at")

  studio             Studio            @relation(fields: [studioId], references: [id], onDelete: Restrict)
  defaultInstructor  User?             @relation("ClassTemplateDefaultInstructor", fields: [defaultInstructorId], references: [id], onDelete: SetNull)
  classes            ScheduledClass[]
  scheduleTemplates  ScheduleTemplate[]

  @@index([studioId])
  @@index([studioId, category])
  @@index([studioId, isFeatured])
  @@index([defaultInstructorId])
  @@map("class_templates")
}

model ScheduledClass {
  id              String      @id @default(cuid())
  studioId        String      @map("studio_id")
  classTemplateId String      @map("class_template_id")
  instructorId    String?     @map("instructor_id")
  startsAt        DateTime    @map("starts_at")
  endsAt          DateTime    @map("ends_at")
  capacity        Int
  status          ClassStatus
  cancelReason    String?     @map("cancel_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  studio        Studio         @relation(fields: [studioId], references: [id], onDelete: Restrict)
  classTemplate ClassTemplate  @relation(fields: [classTemplateId], references: [id], onDelete: Restrict)
  instructor    User?          @relation("ScheduledClassInstructor", fields: [instructorId], references: [id], onDelete: SetNull)
  bookings      Booking[]
  waitlist      WaitlistEntry[]
  attendances   Attendance[]
  qrTokens      QRToken[]

  @@index([studioId])
  @@index([studioId, startsAt])
  @@index([classTemplateId])
  @@index([instructorId])
  @@index([status])
  @@map("scheduled_classes")
}

model Booking {
  id               String         @id @default(cuid())
  studioId         String         @map("studio_id")
  scheduledClassId String         @map("scheduled_class_id")
  userId           String         @map("user_id")
  status           BookingStatus
  cancelSource     CancelSource?  @map("cancel_source")
  cancelledAt      DateTime?      @map("cancelled_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  studio         Studio         @relation(fields: [studioId], references: [id], onDelete: Restrict)
  scheduledClass ScheduledClass @relation(fields: [scheduledClassId], references: [id], onDelete: Restrict)
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([studioId])
  @@index([studioId, scheduledClassId])
  @@index([studioId, userId])
  @@index([scheduledClassId, status])
  @@index([userId])
  @@map("bookings")
}

model WaitlistEntry {
  id               String          @id @default(cuid())
  studioId         String          @map("studio_id")
  scheduledClassId String          @map("scheduled_class_id")
  userId           String          @map("user_id")
  status           WaitlistStatus
  position         Int
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  studio         Studio         @relation(fields: [studioId], references: [id], onDelete: Restrict)
  scheduledClass ScheduledClass @relation(fields: [scheduledClassId], references: [id], onDelete: Restrict)
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([studioId])
  @@index([studioId, scheduledClassId])
  @@index([scheduledClassId, status])
  @@index([userId])
  @@map("waitlist_entries")
}

model Attendance {
  id                  String        @id @default(cuid())
  studioId            String        @map("studio_id")
  scheduledClassId    String        @map("scheduled_class_id")
  userId              String        @map("user_id")
  method              CheckInMethod
  checkedInAt         DateTime      @default(now()) @map("checked_in_at")
  /// Staff/instructor who performed a manual check-in; null for QR or other methods.
  checkedInByUserId String?       @map("checked_in_by_user_id")

  studio         Studio         @relation(fields: [studioId], references: [id], onDelete: Restrict)
  scheduledClass ScheduledClass @relation(fields: [scheduledClassId], references: [id], onDelete: Restrict)
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  checkedInBy    User?          @relation("AttendanceRecordedBy", fields: [checkedInByUserId], references: [id], onDelete: SetNull)

  @@unique([scheduledClassId, userId])
  @@index([studioId])
  @@index([studioId, scheduledClassId])
  @@index([studioId, userId])
  @@index([studioId, userId, checkedInAt])
  @@map("attendances")
}

model QRToken {
  id               String    @id @default(cuid())
  studioId         String    @map("studio_id")
  tokenHash        String    @map("token_hash")
  userId           String?   @map("user_id")
  scheduledClassId String?   @map("scheduled_class_id")
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  /// Reserved for explicit invalidation flows; must be null for QR claim `updateMany`.
  invalidatedAt    DateTime? @map("invalidated_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  studio         Studio          @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  scheduledClass ScheduledClass? @relation(fields: [scheduledClassId], references: [id], onDelete: SetNull)

  @@unique([tokenHash])
  @@index([studioId])
  @@index([studioId, expiresAt])
  @@map("qr_tokens")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  familyId   String    @map("family_id")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Payment {
  id                     String        @id @default(cuid())
  studioId               String        @map("studio_id")
  userId                 String        @map("user_id")
  subscriptionId         String?       @map("subscription_id")
  membershipPlanId       String?       @map("membership_plan_id")
  amountCents            Int           @map("amount_cents")
  currency               String        @default("usd")
  status                 PaymentStatus
  stripePaymentIntentId  String?       @unique @map("stripe_payment_intent_id")
  stripeInvoiceId        String?       @unique @map("stripe_invoice_id")
  paidAt                 DateTime?     @map("paid_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  studio         Studio          @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  membershipPlan MembershipPlan? @relation(fields: [membershipPlanId], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([studioId, userId])
  @@index([studioId, status])
  @@index([userId])
  @@index([subscriptionId])
  @@map("payments")
}

model StripeWebhookEvent {
  id           String    @id @default(cuid())
  stripeEventId String @unique @map("stripe_event_id")
  eventType    String    @map("event_type")
  payload      Json
  processed    Boolean   @default(false)
  processedAt  DateTime? @map("processed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([processed])
  @@index([createdAt])
  @@map("stripe_webhook_events")
}

model BuildJob {
  id                  String           @id @default(cuid())
  studioId            String           @map("studio_id")
  requestedByUserId String           @map("requested_by_user_id")
  platform            BuildJobPlatform
  profile             BuildJobProfile
  status              BuildJobStatus   @default(QUEUED)
  appDisplayName      String           @map("app_display_name")
  appScheme           String           @map("app_scheme")
  expoSlug            String           @map("expo_slug")
  iosBundleIdentifier String           @map("ios_bundle_identifier")
  androidPackage      String           @map("android_package")
  easBuildUrl         String?                @map("eas_build_url")
  artifactUrl         String?                @map("artifact_url")
  errorMessage        String?                @map("error_message")
  errorCategory       BuildJobErrorCategory? @map("error_category")
  submittedAt         DateTime?              @map("submitted_at")
  expoBuildId         String?                @map("expo_build_id")
  expoBuildStatus     String?                @map("expo_build_status")
  lastCheckedAt       DateTime?              @map("last_checked_at")
  requestedAt         DateTime         @default(now()) @map("requested_at")
  startedAt           DateTime?        @map("started_at")
  finishedAt          DateTime?        @map("finished_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  studio      Studio @relation(fields: [studioId], references: [id], onDelete: Restrict)
  requestedBy User   @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@index([studioId])
  @@index([status])
  @@index([requestedAt])
  @@index([startedAt])
  @@index([expoBuildId])
  @@map("build_jobs")
}

/// Phase 18 — idempotent Expo EAS build webhook deliveries (dedupe by body hash).
model ExpoWebhookDelivery {
  id          String   @id @default(cuid())
  deliveryKey String   @unique @map("delivery_key")
  expoBuildId String   @map("expo_build_id")
  processed   Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([expoBuildId])
  @@index([createdAt])
  @@map("expo_webhook_deliveries")
}

/// Phase 20 — studio-scoped staff profile (coach/front-desk/manager metadata).
model StudioStaffProfile {
  id          String    @id @default(cuid())
  studioId    String    @map("studio_id")
  userId      String    @map("user_id")
  staffType   StaffType @default(OTHER) @map("staff_type")
  phone       String?
  bio         String?
  specialties String[]
  photoUrl    String?   @map("photo_url")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([studioId, userId])
  @@index([studioId])
  @@index([studioId, isActive])
  @@map("studio_staff_profiles")
}

model StudioMemberProfile {
  id                       String    @id @default(cuid())
  studioId                 String    @map("studio_id")
  userId                   String    @map("user_id")
  birthdate                DateTime? @map("birthdate")
  emergencyContactName     String?   @map("emergency_contact_name")
  emergencyContactPhone    String?   @map("emergency_contact_phone")
  emergencyContactRelation String?   @map("emergency_contact_relation")
  notes                    String?
  tags                     String[]
  goals                    String?
  injuries                 String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studioId, userId])
  @@index([studioId])
  @@map("studio_member_profiles")
}

/// Phase 25 — one-time day access pass (non-subscription).
/// validForDate stores the UTC midnight of the CDMX calendar date the pass covers.
/// e.g. June 10 CDMX (UTC-6) is stored as 2026-06-10T06:00:00Z.
/// Never use raw UTC date here — always convert using the studio timezone first.
model DayPass {
  id                      String        @id @default(cuid())
  studioId                String        @map("studio_id")
  userId                  String        @map("user_id")
  validForDate            DateTime      @map("valid_for_date")
  priceCents              Int           @map("price_cents")
  currency                String        @default("mxn")
  status                  DayPassStatus @default(PENDING)
  stripeCheckoutSessionId String?       @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?       @unique @map("stripe_payment_intent_id")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  /// One pass per user per studio per calendar day — prevents duplicate purchases.
  @@unique([studioId, userId, validForDate])
  @@index([studioId, userId])
  @@index([studioId, validForDate])
  @@index([status])
  @@map("day_passes")
}

/// Recurring weekly slot definition. The generator reads these to produce ScheduledClass rows.
/// dayOfWeek uses JS convention: 0 = Sunday, 6 = Saturday.
/// startTime is "HH:MM" in the studio's local IANA timezone (never UTC).
model ScheduleTemplate {
  id              String    @id @default(cuid())
  studioId        String    @map("studio_id")
  classTemplateId String    @map("class_template_id")
  instructorId    String?   @map("instructor_id")
  dayOfWeek       Int       @map("day_of_week")
  startTime       String    @map("start_time")
  capacity        Int?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  studio        Studio        @relation(fields: [studioId], references: [id], onDelete: Restrict)
  classTemplate ClassTemplate @relation(fields: [classTemplateId], references: [id], onDelete: Restrict)
  instructor    User?         @relation("ScheduleTemplateInstructor", fields: [instructorId], references: [id])

  @@index([studioId])
  @@index([studioId, active])
  @@index([studioId, dayOfWeek])
  @@map("schedule_templates")
}

/// Immutable log of every generation run (real or dry-run).
model ScheduleGenerationRun {
  id          String                    @id @default(cuid())
  studioId    String                    @map("studio_id")
  triggeredBy ScheduleGenerationTrigger @map("triggered_by")
  userId      String?                   @map("user_id")
  isDryRun    Boolean                   @default(false) @map("is_dry_run")
  fromDate    DateTime                  @map("from_date")
  toDate      DateTime                  @map("to_date")
  generated   Int                       @default(0)
  skipped     Int                       @default(0)
  conflicts   Int                       @default(0)
  errors      Int                       @default(0)
  durationMs  Int?                      @map("duration_ms")
  breakdown   Json?
  startedAt   DateTime                  @default(now()) @map("started_at")
  finishedAt  DateTime?                 @map("finished_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user   User?  @relation("ScheduleGenerationRunUser", fields: [userId], references: [id])

  @@index([studioId])
  @@index([studioId, startedAt])
  @@map("schedule_generation_runs")
}

/// Per-studio automation config. Created on-demand; absence = automation disabled.
model ScheduleAutomationSettings {
  id            String   @id @default(cuid())
  studioId      String   @unique @map("studio_id")
  enabled       Boolean  @default(false)
  minFutureDays Int      @default(90) @map("min_future_days")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Restrict)

  @@map("schedule_automation_settings")
}

/// One-time enrollment fee configuration per studio.
/// Absence = no enrollment fee for that studio.
/// campaignEnabled gates the promo block; all campaign_* fields are only read when campaignEnabled = true.
model StudioEnrollmentSettings {
  id                   String             @id @default(cuid())
  studioId             String             @unique @map("studio_id")
  enrollmentFeeCents   Int                @map("enrollment_fee_cents")
  currency             String             @default("mxn")

  campaignEnabled      Boolean            @default(false) @map("campaign_enabled")
  campaignType         CampaignType?      @map("campaign_type")
  campaignName         String?            @map("campaign_name")
  campaignLimit        Int?               @map("campaign_limit")
  campaignDiscountPct  Int?               @map("campaign_discount_pct")
  campaignAppliesTo    CampaignAppliesTo? @map("campaign_applies_to")

  stripeProductId      String?            @map("stripe_product_id")
  stripePriceId        String?            @map("stripe_price_id")
  active               Boolean            @default(true)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  studio      Studio             @relation(fields: [studioId], references: [id], onDelete: Restrict)
  enrollments MemberEnrollment[]

  @@map("studio_enrollment_settings")
}

/// One enrollment record per user per studio — written only on webhook finalization.
/// memberNumber: sequential across all PAID + WAIVED for the studio.
/// founderNumber: sequential within FIRST_N_PROMO waivers only.
model MemberEnrollment {
  id                      String              @id @default(cuid())
  studioId                String              @map("studio_id")
  userId                  String              @map("user_id")
  settingsId              String              @map("settings_id")
  status                  EnrollmentFeeStatus
  memberNumber            Int?                @map("member_number")
  founderNumber           Int?                @map("founder_number")
  waivedReason            WaivedReason?       @map("waived_reason")
  stripeCheckoutSessionId String?             @unique @map("stripe_checkout_session_id")
  finalizedAt             DateTime?           @map("finalized_at")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  studio   Studio                   @relation(fields: [studioId], references: [id], onDelete: Restrict)
  user     User                     @relation(fields: [userId], references: [id], onDelete: Restrict)
  settings StudioEnrollmentSettings @relation(fields: [settingsId], references: [id], onDelete: Restrict)

  @@unique([studioId, userId])
  @@index([studioId])
  @@index([userId])
  @@map("member_enrollments")
}

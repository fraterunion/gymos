{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "smoke:health": "node scripts/smoke-health.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:stripe-env": "node scripts/smoke-stripe-env.mjs",
    "demo:reset-help": "node scripts/reset-demo.mjs",
    "clean": "rm -rf dist .turbo tsconfig.build.tsbuildinfo",
    "test": "TS_NODE_PROJECT=tsconfig.jest.json jest --config jest.config.unit.ts",
    "test:e2e": "TS_NODE_PROJECT=tsconfig.jest.json jest --config jest.config.e2e.ts --runInBand",
    "test:cov": "TS_NODE_PROJECT=tsconfig.jest.json jest --config jest.config.unit.ts --coverage",
    "seed:ares": "ts-node --project tsconfig.seed.json prisma/seed-ares-production.ts",
    "seed:ares-review": "ts-node --project tsconfig.seed.json prisma/seed-ares-review-accounts.ts",
    "seed:ares-front-desk": "ts-node --project tsconfig.seed.json prisma/seed-ares-front-desk.ts",
    "seed:ares-waiver": "ts-node --project tsconfig.seed.json prisma/seed-ares-waiver.ts",
    "migrate:ares-1.3-schedule": "ts-node --project tsconfig.seed.json prisma/migrate-ares-1.3-schedule.ts",
    "diagnose:ares-demo": "ts-node --project tsconfig.seed.json prisma/diagnose-ares-demo.ts",
    "audit:ares-analytics": "ts-node --project tsconfig.seed.json prisma/audit-ares-analytics.ts",
    "backfill:ares-review-analytics-exclusion": "ts-node --project tsconfig.seed.json prisma/backfill-ares-review-analytics-exclusion.ts",
    "cleanup:ares-demo": "ts-node --project tsconfig.seed.json prisma/cleanup-ares-demo.ts"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eas-cli": "^18.12.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@gymos/config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.27.0",
    "globals": "^16.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}

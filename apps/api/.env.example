NODE_ENV=development
DATABASE_URL=
JWT_SECRET=
JWT_QR_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
BCRYPT_ROUNDS=12
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Phase 4A — Stripe (direct Billing). Required in production; validateEnv sets dev-safe defaults when unset.
# For native member app return routes, set URLs that match expo.scheme + billing paths (see docs/MOBILE.md).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_BILLING_PORTAL_RETURN_URL=

# Phase 13 — FraterUnion platform operators (full GET /settings + PATCH /settings/mobile-config).
# Defaults: domain fraterunion.co; comma-separated extra emails for local/demo seeds.
PLATFORM_OPERATOR_EMAIL_DOMAIN=fraterunion.co
PLATFORM_EXTRA_OPERATOR_EMAILS=admin@ares.demo,owner@pilates.demo

# Phase 15 — EAS build worker (POST .../build-jobs/:jobId/run). Disabled unless BUILD_WORKER_ENABLED=true.
BUILD_WORKER_ENABLED=false
EAS_ACCESS_TOKEN=
EAS_PROJECT_ID=
EAS_PROJECT_SLUG=
EAS_ACCOUNT_NAME=
# MOBILE_APP_ROOT=
# EXPO_PUBLIC_API_URL=
# EAS_BUILD_TIMEOUT_MS=600000
# BUNDLE_DEFAULT_ICON_PATH=./assets/images/icon.png
# BUNDLE_DEFAULT_SPLASH_PATH=./assets/images/splash-icon.png
# BUNDLE_DEFAULT_ADAPTIVE_ICON_PATH=./assets/images/adaptive-icon.png

{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "NODE_ENV",
    "CORS_ORIGIN",
    "BCRYPT_ROUNDS",
    "JWT_ACCESS_TTL",
    "JWT_REFRESH_TTL_DAYS",
    "PORT",
    "EXPO_PUBLIC_API_URL",
    "EXPO_PUBLIC_STUDIO_SLUG",
    "NEXT_PUBLIC_API_URL",
    "WHITELABEL_PROFILE",
    "EXPO_SLUG",
    "APP_DISPLAY_NAME",
    "APP_SCHEME",
    "IOS_BUNDLE_IDENTIFIER",
    "ANDROID_PACKAGE",
    "APP_ICON_PATH",
    "APP_SPLASH_PATH",
    "APP_ADAPTIVE_ICON_PATH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "jest.config.*.ts", "tsconfig*.json"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false,
      "inputs": ["src/**", "test/**", "jest.config.*.ts", "tsconfig*.json"]
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "jest.config.*.ts", "tsconfig*.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
